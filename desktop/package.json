{
  "name": "open-worship",
  "version": "1.0.3",
  "description": "Free, open-source church presentation software",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "dist": "vite build && electron-builder --win --mac --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f"
  },
  "keywords": [
    "church",
    "worship",
    "presentation",
    "lyrics",
    "electron"
  ],
  "author": {
    "name": "inno8",
    "email": "dev@inno8.nl"
  },
  "homepage": "https://github.com/inno8/open-worship",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^36.3.0",
    "electron-builder": "^26.0.6",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "zustand": "^5.0.4"
  },
  "build": {
    "appId": "com.inno8.openworship",
    "productName": "Open Worship",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/koffi/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerHeaderIcon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icons/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons",
      "category": "Utility",
      "maintainer": "inno8 <dev@inno8.nl>"
    },
    "publish": {
      "provider": "github",
      "owner": "inno8",
      "repo": "open-worship"
    }
  }
}
